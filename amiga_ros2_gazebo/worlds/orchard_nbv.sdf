    <!-- Blocking walls — invisible obstacles forcing the
         robot to drive in the 6m alleys between rows -->
    <model name="blocking_wall_row_1">
      <static>true</static>
      <pose>11.00 -6.00 0.400 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>12.00 1.00 0.80</size></box>
          </geometry>
        </collision>
        <!-- No visual: wall is invisible in Gazebo / camera images.
             Lidar (sensor) sees it through the collision. -->
      </link>
    </model>

