    <!-- Levels system: per-alley dynamic loading by performer position.
         In an alley, the FULL row on the robot's right and the FULL row on
         its left load (the two adjacent strings); the far third row stays
         hidden. Walls/ground/lights are not referenced -> always loaded. -->
    <plugin name="gz::sim" filename="dummy">

      <performer name="perf_amiga_kinova">
        <ref>amiga_kinova</ref>
        <geometry><box><size>2 2 2</size></box></geometry>
      </performer>

      <level name="level_alley_south">
        <pose>11.00 -3.00 1.5 0 0 0</pose>
        <geometry><box><size>32 8 10</size></box></geometry>
        <ref>tree_01</ref>
        <ref>tree_02</ref>
        <ref>tree_03</ref>
        <ref>tree_04</ref>
        <ref>tree_05</ref>
        <ref>tree_06</ref>
        <ref>tree_07</ref>
        <ref>tree_08</ref>
      </level>

      <level name="level_alley_north">
        <pose>11.00 3.00 1.5 0 0 0</pose>
        <geometry><box><size>32 8 10</size></box></geometry>
        <ref>tree_05</ref>
        <ref>tree_06</ref>
        <ref>tree_07</ref>
        <ref>tree_08</ref>
        <ref>tree_09</ref>
        <ref>tree_10</ref>
        <ref>tree_11</ref>
        <ref>tree_12</ref>
      </level>

    </plugin>

