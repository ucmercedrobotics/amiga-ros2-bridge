      <pose>0 0.05639 -0.00305 -0 0 3.14159</pose>
    </frame>
    <frame name='camera_link' attached_to='camera_module'/>
    <frame name='color_module' attached_to='end_effector_link'>
      <pose>0 0.05639 -0.00305 -0 0 3.14159</pose>
    </frame>
    <frame name='camera_color_frame' attached_to='color_module'/>
    <frame name='depth_module' attached_to='end_effector_link'>
      <pose>0.0275 0.066 -0.00305 -0 0 3.14159</pose>
    </frame>
    <frame name='camera_depth_frame' attached_to='depth_module'/>
    <frame name='robotiq_85_base_joint' attached_to='end_effector_link'>
      <pose>0 0 0 0 -0 0</pose>
    </frame>
    <frame name='robotiq_85_base_link' attached_to='robotiq_85_base_joint'/>
    <frame name='robotiq_85_left_finger_joint' attached_to='robotiq_85_left_knuckle_link'>
      <pose>0.031526 0 -0.003763 0 -0 0</pose>
    </frame>
    <frame name='robotiq_85_left_finger_link' attached_to='robotiq_85_left_finger_joint'/>
    <frame name='robotiq_85_right_finger_joint' attached_to='robotiq_85_right_knuckle_link'>
      <pose>-0.031526 0 -0.003763 0 -0 0</pose>
    </frame>
    <frame name='robotiq_85_right_finger_link' attached_to='robotiq_85_right_finger_joint'/>
    <frame name='end_effector' attached_to='bracelet_link'>
      <pose>0 0 -0.061525 3.14159 0 3.14159</pose>
    </frame>
    <frame name='end_effector_link' attached_to='end_effector'/>

	</model>
