 		    <!--#######  GPS LINK  #######-->	
		    <link name='GPS_link'>
		    	<pose relative_to="chassis">-0.343 0.27301 1.66757 0 0 0</pose> <!--angles are in radian-->
			<!--Inertial Informatıon of the GPS taken from SolidWorks-->
		     	<inertial>
        			<pose>-0.0218600947156138 0.0419855289307738 0.3606393614418721 0 0 0</pose>
        			<mass>3.90964945047583</mass>
        			<inertia>
          				<ixx>0.0499433745040549</ixx>
          				<ixy>-8.16620300040473E-05</ixy>
          				<ixz>-0.0018718792187362</ixz>
          				<iyy>0.0445451191312299</iyy>
          				<iyz>-0.000101175023181075</iyz>
