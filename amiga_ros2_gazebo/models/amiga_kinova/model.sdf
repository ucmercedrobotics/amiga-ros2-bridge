			<!--Collision information of the rear_left_wheel-->
			
      			
      			<!--#######  GPS PLUGING  #######-->
      			<sensor name="navsat" type="navsat">
			  	<always_on>1</always_on>
			  	<update_rate>1</update_rate>
			  	<topic>navsat</topic>
			</sensor>
		    </link>
		    
		    <!--#######  FRONT CAMERA LINK  #######-->	
		    <link name='front_camera_link'>
		    	<pose relative_to="chassis">-0.24835 0.27301 1.60272 0 0.2618 0</pose> <!--angles are in radian-->
			<!--Inertial Informatıon of the front_camera taken from SolidWorks-->
		     	<inertial>
        			<pose>-0.0130228250132061 -0.000449225919208263 -3.08332527110267E-05 0 0 0</pose>
        			<mass>0.044671376539154</mass>
        			<inertia>
          				<ixx>5.76076422204466E-05</ixx>
          				<ixy>2.14051018622691E-07</ixy>
          				<ixz>-1.04480200804118E-06</ixz>
          				<iyy>8.21049481431884E-06</iyy>
          				<iyz>-4.47549866597229E-08</iyz>
          				<izz>5.25489240957785E-05</izz>
        			</inertia>
      			</inertial>
	      		<!--Visuals of the front_camera colorized with Blender-->
			<visual name='front_camera_link_visual'>
        			<pose>0 0 0 0 0 0</pose>
        			<geometry>
          				<mesh>
            					<scale>1 1 1</scale>
            					<uri>package://amiga_ros2_description/meshes/amiga/front_camera_link.STL</uri>
          				</mesh>
        			</geometry>
          <material>
            <diffuse>0.45 0.45 0.45 1</diffuse>
            <ambient>0.45 0.45 0.45 1</ambient>
          </material>
      			</visual>
			<!--Collision information of the front_camera-->
			
      			
      			<!--#######  FRONT CAMERA RGBD PLUGING  #######-->
      			<sensor name="oak_camera_front" type="rgbd_camera">
          			<pose>0 0 0 0 0 0</pose>
          			<camera>
            				<horizontal_fov>1.047</horizontal_fov>
            				<image>
              					<width>320</width>
              					<height>240</height>
            				</image>
            				<clip>
              					<near>0.1</near>
              					<far>100</far>
            				</clip>
          			</camera>
          			<always_on>1</always_on>
          			<update_rate>30</update_rate>
          			<visualize>true</visualize>
          			<topic>oak_camera_front</topic>
          			<enable_metrics>true</enable_metrics>
        		</sensor>
      			<sensor name="oak_camera_front_imu" type="imu">
          			<always_on>true</always_on>
          			<update_rate>400</update_rate>
          			<imu>
            				<angular_velocity>
              					<x><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></x>
              					<y><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></y>
              					<z><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></z>
            				</angular_velocity>
            				<linear_acceleration>
              					<x><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></x>
              					<y><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></y>
              					<z><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></z>
            				</linear_acceleration>
          			</imu>
          			<topic>oak_camera_front/imu</topic>
      			</sensor>
		    </link>		    
 		    
 		    <!--#######  BACK CAMERA LINK  #######-->	
		    <link name='back_camera_link'>
		    	<pose relative_to="chassis">-0.43765 0.27301 1.60272 0 0.2618 3.14159</pose>
			<!--Inertial Informatıon of the back_camera taken from SolidWorks-->
		     	<inertial>
        			<pose>0.01302282661567 0.000449226300249128 -3.08320037736287E-05 0 0 0</pose>
        			<mass>0.044671376539154</mass>
        			<inertia>
          				<ixx>5.76076422204466E-05</ixx>
          				<ixy>2.14051018622691E-07</ixy>
          				<ixz>1.04480200804118E-06</ixz>
          				<iyy>8.21049481431884E-06</iyy>
          				<iyz>4.47549866597229E-08</iyz>
          				<izz>5.25489240957785E-05</izz>
        			</inertia>
      			</inertial>
	      		<!--Visuals of the back_camera colorized with Blender-->
			<visual name='back_camera_link_visual'>
        			<pose>0 0 0 0 0 -3.14159</pose>
        			<geometry>
          				<mesh>
            					<scale>1 1 1</scale>
            					<uri>package://amiga_ros2_description/meshes/amiga/back_camera_link.STL</uri>
          				</mesh>
        			</geometry>
          <material>
            <diffuse>0.45 0.45 0.45 1</diffuse>
            <ambient>0.45 0.45 0.45 1</ambient>
          </material>
      			</visual>
			<!--Collision information of the back_camera-->
			
      			
      			<!--#######  BACK CAMERA RGBD PLUGING  #######-->
      			<sensor name="oak_camera_back" type="rgbd_camera">
          			<pose>0 0 0 0 0 0</pose>
          			<camera>
            				<horizontal_fov>1.047</horizontal_fov>
            				<image>
              					<width>320</width>
              					<height>240</height>
            				</image>
            				<clip>
              					<near>0.1</near>
              					<far>100</far>
            				</clip>
          			</camera>
          			<always_on>1</always_on>
          			<update_rate>30</update_rate>
          			<visualize>true</visualize>
          			<topic>oak_camera_back</topic>
          			<enable_metrics>true</enable_metrics>
        		</sensor>
		    </link>		    		    
      			
		    
		    
		    
		    

		    <!--connecting these links together using joints-->
		    
		    <!--#######  FRONT RIGHT WHEEL JOINT  #######-->
		    <joint name='front_right_wheel_joint' type='revolute'>
      			<pose relative_to='front_right_wheel_link'>0 0 0 0 0 0</pose>
      			<parent>chassis</parent>
      			<child>front_right_wheel_link</child>
      			<axis>
        			<xyz>0 1 0</xyz>
          			<limit>
            				<lower>-1.79769e+308</lower>
            				<upper>1.79769e+308</upper>
          			</limit>
        			<dynamics>
          				<spring_reference>0</spring_reference>
          				<spring_stiffness>0</spring_stiffness>
        			</dynamics>
      			</axis>
    		    </joint>
		    
		    <!--#######  FRONT LEFT WHEEL JOINT  #######-->
		    <joint name='front_left_wheel_joint' type='revolute'>
      			<pose relative_to='front_left_wheel_link'>0 0 0 0 0 0</pose>
      			<parent>chassis</parent>
      			<child>front_left_wheel_link</child>
      			<axis>
        			<xyz>0 1 0</xyz>
        			<limit>
     			        	<lower>-1.79769e+308</lower>
            				<upper>1.79769e+308</upper>
         	 		</limit>
        			<dynamics>
          				<spring_reference>0</spring_reference>
          				<spring_stiffness>0</spring_stiffness>
        			</dynamics>
      			</axis>
    		    </joint>
		    
		    <!--#######  REAR RIGHT WHEEL JOINT  #######-->
		    <joint name='rear_right_wheel_joint' type='revolute'>
		      	<pose relative_to='rear_right_wheel_link'>0 0 0 0 0 0</pose>
		      	<parent>chassis</parent>
		      	<child>rear_right_wheel_link</child>
		      	<axis>
				<xyz>0 1 0</xyz>
			 	<limit>
			    		<lower>-1.79769e+308</lower>
			    		<upper>1.79769e+308</upper>
			 	</limit>
				<dynamics>
			  		<spring_reference>0</spring_reference>
			  		<spring_stiffness>0</spring_stiffness>
				</dynamics>
		      	</axis>
		    </joint>			

  		    <!--#######  REAR LEFT WHEEL JOINT  #######-->
  		    <joint name='rear_left_wheel_joint' type='revolute'>
		      	<pose relative_to='rear_left_wheel_link'>0 0 0 0 0 0</pose>
		      	<parent>chassis</parent>
		      	<child>rear_left_wheel_link</child>
		      	<axis>
				<xyz>0 1 0</xyz>
			 	<limit>
			    		<lower>-1.79769e+308</lower>
			    		<upper>1.79769e+308</upper>
			 	</limit>
				<dynamics>
					  <spring_reference>0</spring_reference>
					  <spring_stiffness>0</spring_stiffness>
				</dynamics>
		      	</axis>
		    </joint>

   		    <!--#######  GPS JOINT  #######-->
  		    <joint name='GPS_joint' type='fixed'>
		      	<pose relative_to='GPS_link'>0 0 0 0 0 0</pose>
		      	<parent>chassis</parent>
		      	<child>GPS_link</child>
		    </joint>
		    
		    <!--#######  FRONT CAMERA JOINT  #######-->
  		    <joint name='front_camera_joint' type='fixed'>
		      	<pose relative_to='front_camera_link'>0 0 0 0 0 0</pose>
		      	<parent>chassis</parent>
		      	<child>front_camera_link</child>
		    </joint>
		    
		    <!--#######  BACK CAMERA JOINT  #######-->
  		    <joint name='back_camera_joint' type='fixed'>
		    	<pose relative_to="chassis">-0.611435 0.465156 1.55508 0 0 3.14159</pose>
		      	<parent>chassis</parent>
		      	<child>back_camera_link</child>
		    </joint>
		    
