<?xml version="1.0" ?>
<sdf version='1.7'>

	<model name='amiga' canonical_link='chassis'>
		    <!--<pose relative_to='world'>-7 0 0 0 0 0</pose>   the pose is relative to the world by default-->
		    
		    <!--#######  CHASSIS LINK  #######-->
		    <link name='chassis'>
			<!--Inertial Informatıon of the chassis taken from SolidWorks-->
		     	<inertial>
				<pose>-0.084156 0.055422 0.642313 0 -0 0</pose>
				<mass>29.8514</mass>
				<inertia>
		  			<ixx>2.6396625136624</ixx>
		  			<ixy>-0.000921389214172419</ixy>
		  			<ixz>-0.000202110780588825</ixz>
		  			<iyy>1.67612712697157</iyy>
		  			<iyz>3.42820225391418E-06</iyz>
		  			<izz>4.04844807093251</izz>
				</inertia>		
	      		</inertial>
	      		<!--Visuals of the chassis colorized with Blender-->
			<visual name='chassis_link_visual'>
				<pose>0 0 0.65 0 -0 0</pose>
				<geometry>
		  			<mesh>
		    				<scale>1 1 1</scale>
		    				<uri>package://amiga_ros2_description/meshes/amiga/chassis_link.STL</uri>
		  			</mesh>
				</geometry>
        <material>
          <diffuse>0.6 0.6 0.6 1</diffuse>
          <ambient>0.6 0.6 0.6 1</ambient>
        </material>
	      		</visual>
			<!--Collision information of the chassis-->
			<collision name='chassis_link_collision'>
				<pose>0 0 0.80 0 -0 0</pose>
				<geometry>
					<box><size>1.2 0.8 1.0</size></box>
				</geometry>
			</collision>      		
		    			<!-- CHASSIS IMU (added for EKF heading fusion) -->
			<sensor name="chassis_imu" type="imu">
				<always_on>true</always_on>
				<update_rate>100</update_rate>
				<topic>chassis/imu</topic>
				<gz_frame_id>chassis</gz_frame_id>
				<imu>
					<orientation_reference_frame>
						<localization>ENU</localization>
					</orientation_reference_frame>
					<angular_velocity>
						<x><noise type="gaussian"><mean>0</mean><stddev>0.0009</stddev></noise></x>
						<y><noise type="gaussian"><mean>0</mean><stddev>0.0009</stddev></noise></y>
						<z><noise type="gaussian"><mean>0</mean><stddev>0.0009</stddev></noise></z>
					</angular_velocity>
					<linear_acceleration>
						<x><noise type="gaussian"><mean>0</mean><stddev>0.0017</stddev></noise></x>
						<y><noise type="gaussian"><mean>0</mean><stddev>0.0017</stddev></noise></y>
						<z><noise type="gaussian"><mean>0</mean><stddev>0.0017</stddev></noise></z>
					</linear_acceleration>
				</imu>
			</sensor>
		    </link>

		    <!--#######  CHASSIS LINK  #######-->
			<link name='kinova_plate_link'>
      	<pose relative_to="chassis">0.15 -0.915 0.601 0 0 0</pose> <!--angles are in radian-->

			<!--Inertial Informatıon of the kinova_plate taken from SolidWorks (not yet)-->
